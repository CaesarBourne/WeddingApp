  "info": {
    "title": "Wedding Photos API",
    "description": "Backend for a wedding photo app over the Google Photos Library API. Photos live in one app-created album; the API can only see media it uploaded.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateAdminDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "planner@wedding.app"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123!"
          },
          "name": {
            "type": "string",
            "example": "Jane Planner"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "super_admin",
              "guest"
            ],
            "default": "admin"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateGuestDto": {
        "type": "object",
        "properties": {}
      },
      "SetButtonDto": {
        "type": "object",
        "properties": {}
      },
      "SetSeatDto": {
        "type": "object",
        "properties": {}
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@wedding.app"
          },
          "password": {
            "type": "string",
            "example": "ChangeMe123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "GuestTokenDto": {
        "type": "object",
        "properties": {}
      },
      "ModeratePhotoDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "approved",
              "rejected"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "CreateFoodItemDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateFoodItemDto": {
        "type": "object",
        "properties": {}
      },
      "PlaceOrderDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
}