# ──────────────────────────────────────────────────────────────────────────
#  APP
# ──────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins (use * only for local dev)
CORS_ORIGINS=*

# ──────────────────────────────────────────────────────────────────────────
#  AUTH (admin users for YOUR API — not Google)
# ──────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# A first super-admin is auto-seeded on boot from these values.
SEED_ADMIN_EMAIL=admin@wedding.app
SEED_ADMIN_PASSWORD=ChangeMe123!

# ──────────────────────────────────────────────────────────────────────────
#  DATABASE (stores YOUR admin users — NOT the photos)
#  Default: sqlite file. To use Postgres set DB_TYPE=postgres and the DB_* vars.
# ──────────────────────────────────────────────────────────────────────────
DB_TYPE=sqlite
DB_DATABASE=./data/wedding.sqlite
# For postgres:
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=wedding

# ──────────────────────────────────────────────────────────────────────────
#  GOOGLE PHOTOS  (the wedding Google account credentials, stored on backend)
#  Create an OAuth 2.0 "Web application" client in Google Cloud Console,
#  enable the "Photos Library API", then run:  npm run get:token
#  to obtain the REFRESH TOKEN below.
# ──────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/google/callback
# Long-lived refresh token for the wedding account (output of `npm run get:token`)
GOOGLE_REFRESH_TOKEN=

# The app-created album that acts as the single shared "wedding library".
# Leave blank on first run: the app will create one named GOOGLE_PHOTOS_ALBUM_TITLE
# and print its ID to the console — paste it back here so it is reused.
GOOGLE_PHOTOS_ALBUM_ID=
GOOGLE_PHOTOS_ALBUM_TITLE=Our Wedding

# ──────────────────────────────────────────────────────────────────────────
#  CACHE  (baseUrls from Google expire after 60 min — see README)
# ──────────────────────────────────────────────────────────────────────────
# How long (seconds) to cache the album's ordered list of media-item IDs.
# Short, because new uploads change the list. It is also busted on every upload.
ALBUM_INDEX_TTL=300
# How long (seconds) to cache a fresh baseUrl. MUST be < 3600 (Google's expiry).
BASE_URL_TTL=3000

# ──────────────────────────────────────────────────────────────────────────
#  RATE LIMITING
# ──────────────────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
